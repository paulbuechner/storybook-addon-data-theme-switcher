{
  "name": "storybook-addon-data-theme-switcher",
  "version": "3.0.1",
  "description": "A Storybook addon to switch the data-theme attribute on the html element",
  "keywords": [
    "storybook-addon",
    "storybook-addon-theme",
    "storybook-addon-data-theme-switcher",
    "storybook-addon-theme-switcher",
    "storybook",
    "theme",
    "data-theme",
    "react",
    "tailwind",
    "tailwindcss",
    "daisyUI"
  ],
  "homepage": "https://github.com/paulbuechner/storybook-addon-data-theme-switcher",
  "repository": {
    "type": "git",
    "url": "https://github.com/paulbuechner/storybook-addon-data-theme-switcher"
  },
  "license": "MIT",
  "author": "Paul Büchner",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "default": "./dist/preview.js"
    },
    "./manager": "./dist/manager.js",
    "./package.json": "./package.json"
  },
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "prebuild": "pnpm run gen:icon-names",
    "build": "tsdown",
    "build:watch": "pnpm build --watch",
    "build-storybook": "storybook build",
    "changelog": "tsx scripts/changelog.ts",
    "changelog:commit": "git add . && git commit -am 'docs: add changelog' && git push",
    "changelog:format": "prettier --write .changelog",
    "changelog:latest": "tsx scripts/changelog.ts --latest",
    "clean": "rimraf ./dist && rimraf ./src/generated && rimraf ./node_modules",
    "gen:icon-names": "tsx scripts/generate-icon-names.ts",
    "lint": "eslint src/ .storybook/",
    "lint:fix": "eslint src/ .storybook/ --fix",
    "release": "changeset publish",
    "start": "run-p build:watch \"storybook --quiet\"",
    "storybook": "storybook dev -p 6006",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "version": "changeset version"
  },
  "dependencies": {
    "@storybook/icons": "^2.0.1"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@changesets/get-release-plan": "^4.0.15",
    "@changesets/types": "^6.1.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@octokit/rest": "^22.0.1",
    "@playwright/test": "^1.59.1",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-vitest": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/edit-json-file": "^1.7.4",
    "@types/eslint": "^9.6.1",
    "@types/node": "^20.19.39",
    "@types/react": "^19.2.14",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "edit-json-file": "^1.8.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-only-warn": "^1.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-storybook": "^10.3.4",
    "global": "^4.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "npm-run-all2": "^8.0.4",
    "playwright": "^1.59.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "prop-types": "^15.8.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "rimraf": "^6.1.3",
    "storybook": "^10.3.4",
    "tailwindcss": "^4.1.17",
    "tsdown": "^0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "peerDependencies": {
    "react": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^16.8.0 || ^17.0.0 || ^18.0.0 || ^19.0.0",
    "storybook": "^10.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bundler": {
    "managerEntries": [
      "src/preset/manager.ts"
    ],
    "previewEntries": [
      "src/preset/preview.ts",
      "src/preset/index.ts"
    ]
  },
  "storybook": {
    "displayName": "Storybook Addon Data Theme Switcher",
    "supportedFrameworks": [
      "react"
    ],
    "icon": "https://user-images.githubusercontent.com/321738/63501763-88dbf600-c4cc-11e9-96cd-94adadc2fd72.png"
  }
}
